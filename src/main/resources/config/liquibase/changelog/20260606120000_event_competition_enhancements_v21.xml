<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260606120000-event-competition-columns" author="cursor">
        <addColumn tableName="event_competition">
            <column name="discipline_code" type="varchar(32)"/>
            <column name="min_age" type="integer"/>
            <column name="max_age" type="integer"/>
            <column name="min_grade" type="integer"/>
            <column name="max_grade" type="integer"/>
            <column name="max_placements" type="integer" defaultValueNumeric="3"/>
            <column name="registration_deadline" type="${datetimeType}"/>
            <column name="rules_markdown" type="clob"/>
            <column name="requires_team_name" type="boolean" defaultValueBoolean="false"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260606120000-event-competition-registration-columns" author="cursor">
        <addColumn tableName="event_competition_registration">
            <column name="team_name" type="varchar(200)"/>
            <column name="team_display_name" type="varchar(200)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260606120000-event-competition-settings-columns" author="cursor">
        <addColumn tableName="event_competition_settings">
            <column name="points_fourth" type="integer" defaultValueNumeric="0"/>
            <column name="default_max_placements" type="integer" defaultValueNumeric="3"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260606120000-event-competition-group-member-columns" author="cursor">
        <addColumn tableName="event_competition_group_member">
            <column name="member_role" type="varchar(20)" defaultValue="MEMBER"/>
            <column name="sort_order" type="integer" defaultValueNumeric="0"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260606120000-event-competition-registration-confirmation-email" author="cursor">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="event_competition_registration"/>
            <not><columnExists tableName="event_competition_registration" columnName="confirmation_email_sent"/></not>
        </preConditions>
        <addColumn tableName="event_competition_registration">
            <column name="confirmation_email_sent" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="20260606120000-event-competition-settings-winners-email-sent" author="cursor">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="event_competition_settings"/>
            <not><columnExists tableName="event_competition_settings" columnName="winners_published_email_sent_at"/></not>
        </preConditions>
        <addColumn tableName="event_competition_settings">
            <column name="winners_published_email_sent_at" type="${datetimeType}"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
