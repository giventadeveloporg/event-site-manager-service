<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity EventFocusGroup.
    -->
    <changeSet id="20251028-5" author="jhipster">
        <createTable tableName="event_focus_group">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="event_id" type="bigint">
                <constraints nullable="false" />
            </column>
            <column name="focus_group_id" type="bigint">
                <constraints nullable="false" />
            </column>
            <column name="created_at" type="${datetimeType}">
                <constraints nullable="false" />
            </column>
            <column name="updated_at" type="${datetimeType}">
                <constraints nullable="false" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
        <dropDefaultValue tableName="event_focus_group" columnName="created_at" columnDataType="${datetimeType}"/>
        <dropDefaultValue tableName="event_focus_group" columnName="updated_at" columnDataType="${datetimeType}"/>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->
</databaseChangeLog>


