<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260326000000-1" author="system">        <preConditions onFail="MARK_RAN">
        <not><tableExists tableName="official_document_category"/></not>
        </preConditions>
<createTable tableName="official_document_category">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="slug" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="display_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(1024)"/>
            <column name="sort_order" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="official_document_category" columnNames="tenant_id, slug" constraintName="ux_official_document_category_tenant_slug"/>
        <createIndex indexName="idx_official_document_category_tenant_active" tableName="official_document_category">
            <column name="tenant_id"/>
            <column name="is_active"/>
            <column name="sort_order"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
