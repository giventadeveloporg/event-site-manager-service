<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260620120000-1" author="system">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tenant_organization"/>
            <not>
                <columnExists tableName="tenant_organization" columnName="description"/>
            </not>
        </preConditions>
        <addColumn tableName="tenant_organization">
            <column name="description" type="varchar(1000)"/>
            <column name="address_line_1" type="varchar(255)"/>
            <column name="address_line_2" type="varchar(255)"/>
            <column name="city" type="varchar(255)"/>
            <column name="state_province" type="varchar(255)"/>
            <column name="zip_code" type="varchar(20)"/>
            <column name="country" type="varchar(100)"/>
            <column name="website_url" type="varchar(1024)"/>
        </addColumn>
    </changeSet>

    <!-- Separate changesets: manual city-only adds must not block description migration -->
    <changeSet id="20260620120000-2-description" author="system">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tenant_settings"/>
            <not>
                <columnExists tableName="tenant_settings" columnName="description"/>
            </not>
        </preConditions>
        <addColumn tableName="tenant_settings">
            <column name="description" type="varchar(1000)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260620120000-2-city" author="system">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tenant_settings"/>
            <not>
                <columnExists tableName="tenant_settings" columnName="city"/>
            </not>
        </preConditions>
        <addColumn tableName="tenant_settings">
            <column name="city" type="varchar(255)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
