<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <!--
        Added constraints for entity FocusGroupMember.
    -->
    <changeSet id="20251028-4" author="jhipster">
        <addForeignKeyConstraint baseColumnNames="focus_group_id"
                                 baseTableName="focus_group_member"
                                 constraintName="fk_focus_group_member_focus_group_id"
                                 referencedColumnNames="id"
                                 referencedTableName="focus_group"/>

        <addUniqueConstraint
            tableName="focus_group_member"
            columnNames="tenant_id, focus_group_id, user_profile_id"
            constraintName="uq_focus_group_member"/>
    </changeSet>
</databaseChangeLog>


