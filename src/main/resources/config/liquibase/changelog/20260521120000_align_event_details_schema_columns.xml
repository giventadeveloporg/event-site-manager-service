    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Align event_details with JPA entity / Latest_Schema (columns missing from base JHipster createTable) -->

    <changeSet id="20260521120000-promotion-start-date" author="jhipster">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="event_details"/>
            <not><columnExists tableName="event_details" columnName="promotion_start_date"/></not>
        </preConditions>
        <addColumn tableName="event_details">
            <column name="promotion_start_date" type="date" defaultValueDate="1970-01-01">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

