<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <!-- Rows created before enable_google_adsense / homepage_cache_version may have NULL in DB -->
  <changeSet id="20260701120000-1" author="system">
    <preConditions onFail="MARK_RAN">
      <tableExists tableName="tenant_settings"/>
      <columnExists tableName="tenant_settings" columnName="enable_google_adsense"/>
    </preConditions>
    <sql>UPDATE tenant_settings SET enable_google_adsense = false WHERE enable_google_adsense IS NULL;</sql>
  </changeSet>

  <changeSet id="20260701120000-2" author="system">
    <preConditions onFail="MARK_RAN">
      <tableExists tableName="tenant_settings"/>
      <columnExists tableName="tenant_settings" columnName="homepage_cache_version"/>
    </preConditions>
    <sql>UPDATE tenant_settings SET homepage_cache_version = 0 WHERE homepage_cache_version IS NULL;</sql>
  </changeSet>

</databaseChangeLog>
