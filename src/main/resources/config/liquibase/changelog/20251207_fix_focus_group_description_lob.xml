<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Fix FocusGroup description column: ensure TEXT type (avoids PostgreSQL large-object OID issues).
    -->
    <changeSet id="20251207-1-fix-focus-group-description" author="system">        <preConditions onFail="MARK_RAN">
        <tableExists tableName="focus_group"/>
        <columnExists tableName="focus_group" columnName="description"/>
        </preConditions>
<comment>Fix FocusGroup description column: use TEXT instead of LOB/CLOB</comment>
        <modifyDataType tableName="focus_group" columnName="description" newDataType="text"/>
    </changeSet>

</databaseChangeLog>
