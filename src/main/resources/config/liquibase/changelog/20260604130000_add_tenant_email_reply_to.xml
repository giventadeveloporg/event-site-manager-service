<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260604130000-1" author="cursor">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tenant_email_addresses"/>
            <not>
                <columnExists tableName="tenant_email_addresses" columnName="reply_to_email_address"/>
            </not>
        </preConditions>
        <addColumn tableName="tenant_email_addresses">
            <column name="reply_to_email_address" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
