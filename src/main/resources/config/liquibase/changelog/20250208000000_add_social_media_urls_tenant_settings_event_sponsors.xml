<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Add social media URL columns to tenant_settings (all six).
        Schema: varchar(1024) NULL. Only add if column does not exist.
    -->
    <changeSet id="20250208000000-1" author="system">        <preConditions onFail="MARK_RAN">
        <tableExists tableName="tenant_settings"/>
        <not>
        <columnExists tableName="tenant_settings" columnName="facebook_url"/>
        </not>
        </preConditions>
<addColumn tableName="tenant_settings">
            <column name="facebook_url" type="varchar(1024)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="20250208000000-2" author="system">        <preConditions onFail="MARK_RAN">
        <tableExists tableName="tenant_settings"/>
        <not>
