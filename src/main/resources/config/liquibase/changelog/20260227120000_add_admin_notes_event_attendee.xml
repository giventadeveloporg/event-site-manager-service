<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Add admin_notes to event_attendee for admin-only internal notes.
        Schema: TEXT nullable. Only add if column does not exist.
    -->
    <changeSet id="20260227120000-1" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="event_attendee" columnName="admin_notes"/>
            </not>
        </preConditions>
        <addColumn tableName="event_attendee">
            <column name="admin_notes" type="text">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
