<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Add homepage_cache_version to tenant_settings.
        Schema: bigint DEFAULT 0 NOT NULL. Only add if column does not exist.
    -->
    <changeSet id="20260227100000-1" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="tenant_settings" columnName="homepage_cache_version"/>
            </not>
        </preConditions>
        <addColumn tableName="tenant_settings">
            <column name="homepage_cache_version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
